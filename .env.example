# LottoLab Environment Configuration

# Application
APP_NAME=LottoLab
DEBUG=False
ENVIRONMENT=production

# Database
DATABASE_URL=mysql+pymysql://lottolab:your_password@localhost:3306/lottolab

# API
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:8044

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
